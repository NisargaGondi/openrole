# Copy to .env and fill in locally. Never commit .env or service account JSON files.

# --- App ---
APP_ENV=development
DATABASE_URL=sqlite:///./data/openrole.db

# --- Google Cloud / Vertex AI (Gemini) ---
# Absolute path to service account JSON, OR use: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# e.g. gemini-2.0-flash (cheap/fast), gemini-2.5-pro (writing)
VERTEX_MODEL_DEFAULT=gemini-2.0-flash
VERTEX_MODEL_WRITING=gemini-2.0-flash

# --- Optional APIs (later milestones) ---
OPENAI_API_KEY=
APOLLO_API_KEY=
TAVILY_API_KEY=

# --- Sync (Phase B) ---
NOTION_API_KEY=
NOTION_JOBS_DATABASE_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Copy to .env and fill in locally. Never commit .env.

# --- App ---
APP_ENV=development
# SQLite for local dev (default). Use Postgres/Supabase in production.
DATABASE_URL=sqlite:///./data/openrole.db

# --- Google Cloud / Vertex AI (Gemini) ---
# Path to service account JSON, or use `gcloud auth application-default login`
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
# gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-pro, etc.
VERTEX_MODEL_DEFAULT=gemini-2.0-flash
VERTEX_MODEL_WRITING=gemini-2.0-flash

# --- Optional APIs (later milestones) ---
OPENAI_API_KEY=
APOLLO_API_KEY=
TAVILY_API_KEY=

# --- Sync (Phase B) ---
NOTION_API_KEY=
NOTION_JOBS_DATABASE_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON=

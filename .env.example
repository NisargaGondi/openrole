# Copy to .env and fill in locally. Never commit .env or service account JSON files.

# --- App ---
APP_ENV=development
DATABASE_URL=sqlite:///./data/openrole.db

# --- Google Cloud / Vertex AI (Gemini) ---
# Absolute path to service account JSON, OR use: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# gemini-2.5-flash for ingestion; gemini-2.5-pro for outreach writing
VERTEX_MODEL_INGESTION=gemini-2.5-flash
VERTEX_MODEL_DEFAULT=gemini-2.5-flash
VERTEX_MODEL_WRITING=gemini-2.5-pro

# --- People discovery ---
# OpenAI-compatible LLM (used when Vertex AI is not configured).
# OpenRouter: use your sk-or-v1-... key + OPENAI_API_BASE below (auto-detected if base omitted).
OPENAI_API_KEY=
OPENAI_API_BASE=https://openrouter.ai/api/v1
# OpenRouter free models — same sk-or-v1-... key as above
OPENAI_MODEL_INGESTION=moonshotai/kimi-k2.6:free
OPENAI_MODEL_DEFAULT=moonshotai/kimi-k2.6:free
OPENAI_MODEL_WRITING=moonshotai/kimi-k2.6:free
# Alternatives: openrouter/free, meta-llama/llama-3.2-3b-instruct:free
# Direct OpenAI example (paid):
# OPENAI_API_BASE=
# OPENAI_MODEL_INGESTION=gpt-4o-mini
# OPENAI_MODEL_DEFAULT=gpt-4o-mini
# OPENAI_MODEL_WRITING=gpt-4o
APOLLO_API_KEY=
# CareerShift uses local browser login (no API key). Run scripts/careershift_login.py once.
CMU_EMAIL_DOMAIN=andrew.cmu.edu
CMU_SCHOOL_NAME=Carnegie Mellon
TAVILY_API_KEY=

# --- Candidate profile (outreach drafts) ---
# Comma-separated resume paths (.pdf, .md, .txt) — absolute or relative to repo root
CANDIDATE_NAME=
CANDIDATE_RESUME_PATHS=
CANDIDATE_LINKEDIN_URL=
CANDIDATE_GITHUB_URL=
CANDIDATE_WEBSITE_URL=
# Outreach closing line — edit month/year anytime (e.g. December 2026)
CANDIDATE_GRADUATION=December 2026
CANDIDATE_ROLE_SEARCH=full-time roles

# --- Sync (Phase B) ---
NOTION_API_KEY=
NOTION_JOBS_DATABASE_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON=
